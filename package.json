{
  "name": "algasensors-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "biome format --write",
    "spartan:add": "ng g @spartan-ng/cli:ui"
