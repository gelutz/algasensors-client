{
    "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "defaultBranch": "main"
    },
    "files": {
        "ignoreUnknown": false,
        "ignore": [
            "node_modules",
            "dist",
            "build",
            ".angular"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentSize": 2,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "enabled": true,
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "es5",
            "bracketSpacing": true,
            "arrowParentheses": "always"
        },
        "parser": {
            "unsafeParameterDecoratorsEnabled": true
        }
    },
    "json": {
        "formatter": {
            "enabled": true,
            "indentSize": 2
        },
        "parser": {
            "allowTrailingComma": false
        }
    }
}